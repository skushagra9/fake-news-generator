# Copy to .env and fill in values. Never commit .env.

# === OpenAI ===
# Required. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-replace-me
# Model used for both transformation and chat. gpt-4o-mini is cheap + fast and
# supports JSON mode + streaming, which is all we need here.
OPENAI_MODEL=gpt-4o-mini

# === Database ===
# Used by backend + Prisma migrations inside the compose network.
POSTGRES_USER=fakenews
POSTGRES_PASSWORD=fakenews
POSTGRES_DB=fakenews
# This DATABASE_URL is what the backend container sees (host = "db").
DATABASE_URL=postgresql://fakenews:fakenews@db:5432/fakenews?schema=public

# === Redis (BullMQ broker) ===
REDIS_URL=redis://redis:6379

# === Backend ===
NODE_ENV=production
PORT=4000
# CORS origin for the frontend (only used in dev; in compose the frontend's
# nginx proxies /api so CORS is a non-issue).
CORS_ORIGIN=http://localhost:5173

# === Frontend ===
# At build time Vite inlines this. In compose we leave it blank so the
# frontend uses relative /api URLs proxied by nginx.
VITE_API_BASE_URL=
